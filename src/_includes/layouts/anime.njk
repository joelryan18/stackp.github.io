---
layout: layouts/base.njk
bodyClass: no3d page
---
<a class="skip-link" href="#main">Skip to content</a>

<!-- Stackime intro splash (enma.lol-style: anime art reveals inside the letters
     while the outline stroke-draws; anime.js picks the banner + dismisses it) -->
<div class="ani-intro" id="aniIntro" aria-hidden="true">
  <svg class="ani-intro__svg" viewBox="0 0 1200 260">
    <defs>
      <mask id="aniIntroMask" maskUnits="userSpaceOnUse" x="0" y="0" width="1200" height="260">
        <text class="ani-intro__word" x="600" y="185" text-anchor="middle" fill="#fff">STACKIME</text>
      </mask>
    </defs>
    <image class="ani-intro__art" id="aniIntroArt" x="0" y="0" width="1200" height="260"
           preserveAspectRatio="xMidYMid slice" mask="url(#aniIntroMask)"
           href="https://s4.anilist.co/file/anilistcdn/media/anime/banner/178789-9nHWmoRLlcLu.jpg"/>
    <text class="ani-intro__word ani-intro__word--draw" x="600" y="185" text-anchor="middle">STACKIME</text>
  </svg>
  <p class="ani-intro__tag">スタッキメ · anime list × stackwith.me</p>
</div>

<header class="nav is-scrolled">
  <a href="/" class="nav__brand" aria-label="AXON home">
    <span class="nav__mark" aria-hidden="true">
      <svg viewBox="0 0 28 28"><path d="M2 14h5l3-7 6 14 3-7h7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round"/></svg>
    </span>
    <span class="nav__word">AXON</span>
  </a>
  <nav class="nav__links" aria-label="Primary">
    <a href="/" data-index="01">Home</a>
    <a href="/blog/" data-index="02">Blog</a>
    <a href="/anime.html" data-index="03" aria-current="page">Anime</a>
  </nav>
  <div class="nav__right">
    <button type="button" class="btn btn--signal" id="aniNavAuth" hidden>Sign in</button>
  </div>
</header>

<main id="main" class="ani">
{{ content | safe }}
</main>

<footer class="footer">
  <div class="footer__base">
    <span>© <span id="year">2026</span> AXON</span>
    <span><a href="/privacy.html">Privacy</a> · <a href="/terms.html">Terms</a> · <a href="/about.html">About</a> · <a href="/contact.html">Contact</a></span>
    <span>MADE&nbsp;WITH&nbsp;INTENT</span>
  </div>
</footer>

<script src="{{ assets.consent }}" defer></script>
<script src="{{ assets.anime }}" defer></script>
<script>document.getElementById("year").textContent = new Date().getFullYear();</script>
