---
layout: layouts/base.njk
bodyClass: no3d page
---
<a class="skip-link" href="#main">Skip to content</a>

<!-- Stackime intro splash (enma.lol clips a real <video> inside its letters;
     this is the asset-free cut — three banner frames Ken-Burns-crossfade inside
     the mask while the outline stroke-draws, then a sheen sweeps through.
     anime.js shuffles the frames + dismisses the overlay) -->
<div class="ani-intro" id="aniIntro" aria-hidden="true">
  <svg class="ani-intro__svg" viewBox="0 0 1400 320">
    <defs>
      <mask id="aniIntroMask" maskUnits="userSpaceOnUse" x="0" y="0" width="1400" height="320">
        <text class="ani-intro__word" x="700" y="225" text-anchor="middle" fill="#fff">STACKIME</text>
      </mask>
      <linearGradient id="aniIntroSheenGrad" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0" stop-color="#fff" stop-opacity="0"/>
        <stop offset=".5" stop-color="#fff" stop-opacity=".5"/>
        <stop offset="1" stop-color="#fff" stop-opacity="0"/>
      </linearGradient>
      <clipPath id="aniIntroClip">
        <text class="ani-intro__word" x="700" y="225" text-anchor="middle">STACKIME</text>
      </clipPath>
    </defs>
    <g mask="url(#aniIntroMask)">
      <image class="ani-intro__art ani-intro__art--1" id="aniIntroArt1" x="0" y="0" width="1400" height="320"
             preserveAspectRatio="xMidYMid slice"
             href="https://s4.anilist.co/file/anilistcdn/media/anime/banner/178789-9nHWmoRLlcLu.jpg"/>
      <image class="ani-intro__art ani-intro__art--2" id="aniIntroArt2" x="0" y="0" width="1400" height="320"
             preserveAspectRatio="xMidYMid slice"
             href="https://s4.anilist.co/file/anilistcdn/media/anime/banner/21-wf37VakJmZqs.jpg"/>
      <image class="ani-intro__art ani-intro__art--3" id="aniIntroArt3" x="0" y="0" width="1400" height="320"
             preserveAspectRatio="xMidYMid slice"
             href="https://s4.anilist.co/file/anilistcdn/media/anime/banner/182205-fRUoKv6f2JAq.jpg"/>
    </g>
    <!-- the real video, clipped into the letters exactly like enma's /intro.mp4
         (self-generated signal-rush clip — royalty-free because we own it);
         the banner frames above remain as the no-video fallback -->
    <foreignObject x="0" y="0" width="1400" height="320" clip-path="url(#aniIntroClip)">
      <video class="ani-intro__video" id="aniIntroVideo" src="/assets/video/intro-signal.mp4"
             autoplay muted playsinline preload="auto"></video>
    </foreignObject>
    <g mask="url(#aniIntroMask)">
      <rect class="ani-intro__sheen" x="0" y="0" width="320" height="320" fill="url(#aniIntroSheenGrad)"/>
    </g>
    <text class="ani-intro__word ani-intro__word--draw" x="700" y="225" text-anchor="middle">STACKIME</text>
  </svg>
  <p class="ani-intro__tag">スタッキメ · anime list × stackwith.me</p>
</div>

<header class="nav is-scrolled">
  <a href="/" class="nav__brand" aria-label="AXON home">
    <span class="nav__mark" aria-hidden="true">
      <svg viewBox="0 0 28 28"><path d="M2 14h5l3-7 6 14 3-7h7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round"/></svg>
    </span>
    <span class="nav__word">AXON</span>
  </a>
  <nav class="nav__links" aria-label="Primary">
    <a href="/" data-index="01">Home</a>
    <a href="/blog/" data-index="02">Blog</a>
    <a href="/anime.html" data-index="03" aria-current="page">Anime</a>
  </nav>
  <div class="nav__right">
    <button type="button" class="btn btn--signal" id="aniNavAuth" hidden>Sign in</button>
  </div>
</header>

<main id="main" class="ani">
{{ content | safe }}
</main>

<footer class="footer">
  <div class="footer__base">
    <span>© <span id="year">2026</span> AXON</span>
    <span><a href="/privacy.html">Privacy</a> · <a href="/terms.html">Terms</a> · <a href="/about.html">About</a> · <a href="/contact.html">Contact</a></span>
    <span>MADE&nbsp;WITH&nbsp;INTENT</span>
  </div>
</footer>

<script src="{{ assets.consent }}" defer></script>
<script src="{{ assets.anime }}" defer></script>
<script>document.getElementById("year").textContent = new Date().getFullYear();</script>
