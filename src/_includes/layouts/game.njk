---
layout: layouts/base.njk
bodyClass: page game-body
viewportFit: true
themeColor: "#05070C"
extraStylesheet: gamecss
---
<a class="skip-link" href="#main">Skip to content</a>

<canvas id="gamefx" class="gamefx" aria-hidden="true"></canvas>
<div class="g-bootveil" id="gBootVeil" aria-hidden="true"></div>

<noscript><style>
  .gamefx, .g-hud, .g-menu, .g-end, .g-dmg, .g-bootveil, .g-spec { display: none !important; }
  .game-fallback { display: block !important; }
</style></noscript>

<header class="nav is-scrolled game-nav">
  <a href="/" class="nav__brand" aria-label="stackwith.me home">
    <span class="nav__mark" aria-hidden="true">
      <svg viewBox="0 0 28 28"><path d="M2 14h5l3-7 6 14 3-7h7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round"/></svg>
    </span>
    <span class="nav__word">STACKWITH.ME</span>
  </a>
  <nav class="nav__links" aria-label="Primary">
    <a href="/lab.html" data-index="01">Lab</a>
    <a href="/blog/" data-index="02">Blog</a>
    <a href="/about.html" data-index="03">About</a>
  </nav>
</header>

<!-- lobby / pause menu -->
<div class="g-menu is-on" id="gMenu">
  <div class="g-menu__core">
    <p class="g-menu__eyebrow">[ ARENA · SOLO VS 11 · SQUADS OF 4 ]</p>
    <h1 class="g-menu__title">SIGNAL<i>STRIKE</i></h1>
    <p class="g-menu__sub" id="gMenuTitle">LAST NODE STANDING · THE RING ALWAYS CLOSES</p>
    <button class="g-menu__play" id="gPlay" type="button">DEPLOY</button>
    <ul class="g-menu__keys" aria-label="Controls">
      <li><b>WASD</b> move</li><li><b>SHIFT</b> sprint</li><li><b>SPACE</b> jump</li>
      <li><b>CTRL</b> crouch / slide</li><li><b>LMB</b> fire</li><li><b>RMB</b> aim (LANCE)</li>
      <li><b>R</b> refeed</li><li><b>1/2</b> weapon</li><li><b>Q</b> hardlight wall</li>
      <li><b>V</b> camera view</li>
    </ul>

    <!-- ARSENAL — pick two weapons into the deploy loadout -->
    <div class="g-arsenal" id="gArsenal">
      <p class="g-arsenal__head">ARSENAL <i id="gArsenalSel">PICKING · SLOT 1</i></p>
      <div class="g-arsenal__slots">
        <button class="g-arsenal__slot is-sel" id="gSlot0" type="button"><span>SLOT 1</span><b>PULSE-7</b></button>
        <button class="g-arsenal__slot" id="gSlot1" type="button"><span>SLOT 2</span><b>LANCE-1</b></button>
      </div>
      <ul class="g-arsenal__guns" id="gGuns" aria-label="Weapon catalog"></ul>
      <button class="g-arsenal__view" id="gViewBtn" type="button">CAMERA · FIRST PERSON</button>
    </div>
    <!-- SQUAD LINK — online rooms with friends (Supabase Realtime relay) -->
    <div class="g-squad" id="gSquad">
      <p class="g-squad__head">SQUAD LINK <i id="gSquadState">OFFLINE</i></p>
      <div class="g-squad__make" id="gSquadMake">
        <input id="gCallsign" class="g-squad__in" maxlength="10" spellcheck="false" autocomplete="off" placeholder="CALLSIGN" aria-label="Callsign" />
        <button id="gHost" class="g-squad__btn" type="button">CREATE ROOM</button>
        <span class="g-squad__or">/</span>
        <input id="gCode" class="g-squad__in g-squad__in--code" maxlength="4" spellcheck="false" autocomplete="off" placeholder="CODE" aria-label="Room code" />
        <button id="gJoin" class="g-squad__btn" type="button">JOIN</button>
      </div>
      <div class="g-squad__room" id="gSquadRoom" hidden>
        <div class="g-squad__row">
          <b class="g-squad__code" id="gRoomCode">----</b>
          <button id="gCopy" class="g-squad__btn" type="button">COPY INVITE LINK</button>
          <button id="gLeave" class="g-squad__btn g-squad__btn--ghost" type="button">LEAVE</button>
        </div>
        <ul class="g-squad__roster" id="gRoster" aria-label="Squad roster"></ul>
        <p class="g-squad__hint" id="gSquadHint">SHARE THE CODE — UP TO 4 NODES DROP TOGETHER, BOTS FILL THE REST.</p>
      </div>
    </div>
    <p class="g-menu__note">Desktop + mouse only. Pointer locks on deploy — ESC pauses.</p>
  </div>
</div>

<!-- in-match HUD -->
<div class="g-hud" id="gHud" aria-hidden="true">
  <div class="g-vig" id="gVig"></div>
  <div class="g-cross" id="gCross"><i></i><i></i><i></i><i></i><s></s></div>
  <div class="g-hitmark" id="gHitmark"><i></i><i></i><i></i><i></i></div>
  <div class="g-dmgdir" id="gDmgDir" aria-hidden="true"><i></i></div>
  <div class="g-compass" id="gCompass"></div>
  <p class="g-banner" id="gBanner"></p>

  <div class="g-vitals">
    <div class="g-bar g-bar--sh"><i id="gShBar"></i></div>
    <div class="g-bar g-bar--hp"><i id="gHpBar"></i></div>
    <span class="g-vitals__nums"><b id="gShNum">75</b> / <b id="gHpNum">100</b></span>
  </div>

  <div class="g-weapon">
    <span class="g-weapon__name" id="gWName">PULSE-7</span>
    <span class="g-weapon__ammo"><b id="gAmmo">30</b><i>/</i><s id="gReserve">180</s></span>
    <span class="g-weapon__util" id="gBarCd">Q</span>
  </div>

  <div class="g-top">
    <span class="g-top__cell">UNITS <b id="gAlive">12</b></span>
    <span class="g-top__cell">ELIMS <b id="gKills">00</b></span>
    <span class="g-top__cell g-top__cell--storm" id="gStorm">RING HOLDS</span>
  </div>

  <canvas class="g-mini" id="gMini" width="148" height="148"></canvas>
  <ul class="g-feed" id="gFeed" aria-live="polite"></ul>
</div>

<div class="g-spec" id="gSpec"><span>SPECTATING</span><b id="gSpecName">—</b></div>
<div class="g-dmg" id="gDmg" aria-hidden="true"></div>

<!-- end screen -->
<div class="g-end" id="gEnd">
  <p class="g-end__kicker">[ MATCH REPORT ]</p>
  <h2 class="g-end__title" id="gEndTitle">SIGNAL SECURED</h2>
  <div class="g-end__stats" id="gEndStats"></div>
  <div class="g-end__actions">
    <button class="g-menu__play" id="gAgain" type="button">RE-DEPLOY</button>
    <a class="g-end__leave" href="/lab.html">LEAVE ARENA → THE LAB</a>
  </div>
</div>

<button class="g-snd" id="gSnd" type="button" aria-pressed="true" aria-label="Toggle sound">
  <span class="g-snd__eq" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
  <span>SND</span>
</button>

<main id="main" class="game">
{{ content | safe }}
</main>

<script type="module" src="{{ assets.game3d }}"></script>
<script src="{{ assets.consent }}" defer></script>
